{
  "name": "message-archive-utility-desktop",
  "description": "A local-first Mac app for archiving, searching, and exporting iPhone messages.",
  "version": "0.1.0",
  "private": true,
  "productName": "Message Archive Utility",
  "author": "Message Archive Utility",
  "copyright": "Copyright © 2026 Message Archive Utility",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack:mac": "../scripts/build-backend-executable.sh && ../scripts/build-desktop.sh && electron-builder --mac --dir",
    "pack:mac:dmg": "../scripts/build-backend-executable.sh && ../scripts/build-desktop.sh && electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.messagearchive.utility",
    "productName": "Message Archive Utility",
    "asar": true,
    "npmRebuild": false,
    "afterPack": "../scripts/patch-mac-info-plist.cjs",
    "directories": {
      "output": "../release/mac"
    },
    "files": [
      "main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../release/backend/message-archive-backend",
        "to": "backend/message-archive-backend"
      }
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.productivity",
      "identity": "-",
      "extendInfo": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "127.0.0.1": {
              "NSIncludesSubdomains": false,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionAllowsInsecureHTTPSLoads": false,
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            },
            "localhost": {
              "NSIncludesSubdomains": false,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionAllowsInsecureHTTPSLoads": false,
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            }
          }
        },
        "NSAudioCaptureUsageDescription": "Message Archive does not use audio capture.",
        "NSBluetoothAlwaysUsageDescription": "Message Archive does not use Bluetooth.",
        "NSBluetoothPeripheralUsageDescription": "Message Archive does not use Bluetooth.",
        "NSCameraUsageDescription": "Message Archive does not use the camera.",
        "NSMicrophoneUsageDescription": "Message Archive does not use the microphone."
      }
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "title": "Message Archive Utility ${version}",
      "contents": [
        {
          "x": 140,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}

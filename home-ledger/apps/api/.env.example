# Home Ledger SaaS API local settings
#
# Do not commit real production values here. Keep secrets in your local
# environment or deployment secret manager.

APP_ENV=local
NODE_ENV=development
PORT=4000

AUTH_PROVIDER=dev
DEV_AUTH_ENABLED=true
DEV_AUTH_EMAIL=dev@example.test
DEV_AUTH_DISPLAY_NAME=Local Developer
SESSION_COOKIE_NAME=home_ledger_session

FILE_STORAGE_DRIVER=local
# For production object storage, set FILE_STORAGE_DRIVER=s3 and configure an
# S3-compatible private bucket. Keep access keys in deployment secrets.
# FILE_STORAGE_BUCKET=home-ledger-documents
# FILE_STORAGE_REGION=us-east-1
# FILE_STORAGE_ENDPOINT=
# FILE_STORAGE_ACCESS_KEY_ID=
# FILE_STORAGE_SECRET_ACCESS_KEY=
# FILE_STORAGE_FORCE_PATH_STYLE=false
# FILE_STORAGE_UPLOAD_URL_TTL_SECONDS=600
# FILE_STORAGE_DOWNLOAD_URL_TTL_SECONDS=300
BILLING_PROVIDER=none
# OCR_MODE=disabled queues OCR status without extracting text.
# OCR_MODE=fake is deterministic and intended for tests/local API checks only.
OCR_MODE=disabled
ANALYTICS_ENABLED=false

# DATABASE_URL is used by the API runtime and explicit migration commands.
# TEST_DATABASE_URL is required for schema smoke checks and test resets.

DATABASE_URL=postgres://home_ledger:home_ledger@localhost:5432/home_ledger_dev
TEST_DATABASE_URL=postgres://home_ledger:home_ledger@localhost:5432/home_ledger_test

# Optional database tuning.
DB_POOL_MAX=10

# Optional. Defaults to pgmigrations.
MIGRATIONS_TABLE=pgmigrations

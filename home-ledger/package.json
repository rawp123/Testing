{
  "name": "home-basis-tracker-web",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:website": "node website/server.cjs",
    "start:website": "node website/server.cjs",
    "dev": "node scripts/serve-frontend.mjs",
    "start": "node scripts/serve-frontend.mjs",
    "check:syntax": "bash -n scripts/build-signed-dmg.sh && node --check frontend/app.js && node --check backend/domain/model.js && node --check backend/domain/backup.js && node --check backend/domain/tutorial-data.js && node --check backend/storage/document-storage.js && node --check backend/storage/records-storage.js && node --check desktop/main.cjs && node --check desktop/preload.cjs && node --check desktop/storage-helpers.cjs && node --check scripts/serve-frontend.mjs && node --check scripts/render-qa.cjs && node --check scripts/beta-qa.cjs && node --check scripts/private-document-qa.cjs && node --check scripts/smoke-packaged-app.mjs && node --check scripts/smoke-dmg-app.mjs && node --check website/server.cjs",
    "check:model": "node scripts/check-model.mjs",
    "test": "node --test tests/*.test.mjs",
    "dev:api": "npm --workspace apps/api run dev",
    "start:api": "npm --workspace apps/api run start",
    "test:api": "npm --workspace apps/api test",
    "check:api": "npm --workspace apps/api run check:syntax",
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "test:web": "npm --workspace apps/web test",
    "check:web": "npm --workspace apps/web run check:syntax",
    "saas:db:migrate": "npm --workspace apps/api run db:migrate",
    "saas:db:rollback": "npm --workspace apps/api run db:rollback",
    "saas:db:reset:test": "npm --workspace apps/api run db:reset:test",
    "saas:db:check": "npm --workspace apps/api run db:check",
    "qa:render": "env -u ELECTRON_RUN_AS_NODE ./desktop/node_modules/.bin/electron scripts/render-qa.cjs",
    "qa:beta": "env -u ELECTRON_RUN_AS_NODE ./desktop/node_modules/.bin/electron scripts/beta-qa.cjs",
    "qa:private-documents": "env -u ELECTRON_RUN_AS_NODE ./desktop/node_modules/.bin/electron scripts/private-document-qa.cjs",
    "smoke:desktop": "npm --prefix desktop run smoke",
    "smoke:packaged": "node scripts/smoke-packaged-app.mjs",
    "smoke:dmg": "node scripts/smoke-dmg-app.mjs",
    "pack:mac": "npm --prefix desktop run pack:mac",
    "pack:mac:dmg:signed": "npm --prefix desktop run pack:mac:dmg:signed",
    "check:mac-package": "npm --prefix desktop run check:package"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "pdfjs-dist": "^6.0.227",
    "tesseract.js": "^7.0.0"
  }
}

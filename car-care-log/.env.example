# Optional signed release environment. Keep real values outside Git.
# These can use the same Apple Developer account credentials as Message Archive Utility.
# CSC_NAME=Your Name (TEAMID)
# Full certificate names also work:
# CSC_NAME=Developer ID Application: Your Name (TEAMID)
# APPLE_NOTARIZE_KEYCHAIN_PROFILE=car-care-log-notary
# APPLE_NOTARIZE_KEYCHAIN=/path/to/login.keychain-db
# APPLE_API_KEY=/path/to/AuthKey_XXXXXXXXXX.p8
# APPLE_API_KEY_ID=XXXXXXXXXX
# APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000
# APPLE_API_ISSUER is required for Team API keys and omitted for Individual API keys.
# APPLE_ID=you@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=TEAMID
# Legacy aliases are also supported:
# APPLE_KEYCHAIN_PROFILE=car-care-log-notary
# APPLE_KEYCHAIN=/path/to/login.keychain-db

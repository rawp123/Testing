{
  "name": "car-care-log",
  "version": "0.1.0",
  "description": "A local-first desktop app for vehicle service records, receipts, and maintenance history.",
  "author": "Robert Parrish",
  "private": true,
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "dev:website": "node website/server.cjs",
    "start:website": "node website/server.cjs",
    "icon:generate": "node scripts/generate-app-icon.mjs",
    "build": "npm run typecheck && electron-vite build",
    "package:mac": "npm run icon:generate && npm run build && electron-builder --config electron-builder.config.cjs --mac --publish never && npm run verify:runtime-assets -- --app \"release/mac-arm64/Car Care Log.app\"",
    "package:mac:signed": "bash scripts/build-signed-dmg.sh",
    "verify:runtime-assets": "node scripts/verify-runtime-assets.mjs",
    "smoke:fresh-user": "vitest run tests/freshUserSmoke.test.ts",
    "smoke:packaged": "node scripts/smoke-packaged-app.mjs",
    "qa:private-ocr": "node scripts/run-private-ocr-qa.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@tesseract.js-data/eng": "^1.0.0",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.10.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^7.3.3",
    "vitest": "^3.2.4"
  }
}
